# Copy this file to .env and fill in your values.
# .env is git-ignored. Never commit real credentials.
#
# Auth option 1: Personal Access Token (quickest for local dev)
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapi...

# Auth option 2: Service Principal / OAuth M2M (recommended for CI/deployed)
# DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
# DATABRICKS_CLIENT_ID=<service-principal-application-id>
# DATABRICKS_CLIENT_SECRET=<service-principal-secret>
# DATABRICKS_AZURE_TENANT_ID=<azure-tenant-id>   # Azure only

# Auth option 3: Named profile from ~/.databrickscfg
# DATABRICKS_CONFIG_PROFILE=my-profile

# Target resources (used by the query helpers)
DATABRICKS_WAREHOUSE_ID=487241390a777647
DATABRICKS_CATALOG=si_prod_catalog
DATABRICKS_SCHEMA=nw_harmonized_sensitive

# Single table extraction (used by test_connection.py --table)
DATABRICKS_TABLE=si_prod_catalog.nw_harmonized_sensitive.t_sccm_v_r_system_temp
DATABRICKS_LIMIT=1000

# Device ETL tables (used by extract_devices.py)
DATABRICKS_TABLE_DEVICES=si_prod_catalog.nw_harmonized_sensitive.t_sccm_v_r_system_temp
DATABRICKS_TABLE_WINDOWS_UPDATE=si_prod_catalog.nw_harmonized_sensitive.t_sccm_gs_windowsupdate
DATABRICKS_TABLE_INSTALLED_SOFTWARE=si_prod_catalog.nw_harmonized_sensitive.t_sccm_gs_installed_software
