# Copy this file to .env and fill in your values.
# .env is git-ignored. Never commit real credentials.

# Prod workspace -- used for si_prod_catalog tables
DATABRICKS_HOST_PROD=https://nationwide-irm-prod-ohio.cloud.databricks.com
DATABRICKS_TOKEN_PROD=<prod-workspace-token>
DATABRICKS_WAREHOUSE_ID=487241390a777647

# Test workspace -- used for si_test_catalog tables
DATABRICKS_HOST_TEST=https://nationwide-irm-test-ohio.cloud.databricks.com
DATABRICKS_TOKEN_TEST=<test-workspace-token>
DATABRICKS_WAREHOUSE_ID_TEST=ed10729e21418123

# If both workspaces share the same token, set DATABRICKS_TOKEN and leave
# DATABRICKS_TOKEN_PROD and DATABRICKS_TOKEN_TEST unset -- both will fall back to it.
# DATABRICKS_TOKEN=<shared-token>

# Discovery (used by test_connection.py)
DATABRICKS_CATALOG=si_prod_catalog
DATABRICKS_SCHEMA=nw_harmonized_sensitive

# Single table extraction (used by test_connection.py --table)
DATABRICKS_TABLE=si_prod_catalog.nw_harmonized_sensitive.t_sccm_v_r_system_temp
DATABRICKS_LIMIT=1000
DATABRICKS_QUERY_TIMEOUT=300

# Device ETL tables (used by extract_devices.py)
DATABRICKS_TABLE_DEVICES=si_prod_catalog.nw_harmonized_sensitive.t_sccm_v_r_system_temp
DATABRICKS_TABLE_WINDOWS_UPDATE=si_test_catalog.nw_harmonized_sensitive.t_sccm_gs_windowsupdate
DATABRICKS_TABLE_INSTALLED_SOFTWARE=si_test_catalog.nw_harmonized_sensitive.t_sccm_gs_installed_software
# User identity table (test workspace) -- replace with actual table name once confirmed
DATABRICKS_TABLE_USERS=si_test_catalog.nw_harmonized_sensitive.REPLACE_WITH_USER_TABLE_NAME
